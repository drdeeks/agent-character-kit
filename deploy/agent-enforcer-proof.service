[Unit]
Description=AIK Enforcer self-respawn PROOF (user-systemd)
After=network.target
StartLimitIntervalSec=60
StartLimitBurst=10

[Service]
Type=simple
ExecStart=/usr/bin/env ENFORCER_SOCKET=%t/agent-enforcer/main.sock AGENT_WORKSPACE=%t/agent-enforcer/ws /usr/bin/node /home/ubuntu/qwen-cloud-2026/agent-character-kit/node/enforcer/agent_enforcer_daemon.js
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
