  "scripts": {
    "test": "node --test node/tests/*.test.js",
    "start": "node bin/aik.js",
    "install": "node bin/install.js",
    "ack-install": "node bin/install.js"
  },
  "keywords": [
    "agent", "identity", "enforcement", "knowledge", "memory",
    "semantic-search", "hooks", "yaml", "frontmatter",
    "claude", "cursor", "gemini", "hermes", "opencode"
