    "glob": "^10.3.0",
    "commander": "^11.1.0"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "node/",
    "python/",
    "deploy/",
    "README.md",
    "LICENSE"
  ]
}
